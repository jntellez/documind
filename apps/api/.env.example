# Docker Compose default (used by the API container):
DATABASE_URL="postgres://postgres:password@postgres:5432/documinddb"
# Local host alternative when running the API outside Docker:
# DATABASE_URL="postgres://postgres:password@localhost:5432/documinddb"
PORT=3000
JWT_SECRET=change-me
# Set this to your AI Gateway base URL. It must NOT reuse the Documind API port above.
# Example: if the gateway runs separately on port 8787, use http://localhost:8787
AI_GATEWAY_URL=http://localhost:8787
AI_GATEWAY_TIMEOUT_MS=15000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
