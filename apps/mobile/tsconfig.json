{
  "extends": [
    "expo/tsconfig.base",
    "../../tsconfig.base.json"
  ],
  "compilerOptions": {
    "types": [
      "jest"
    ],
    "paths": {
      "@documind/types": [
        "../../packages/types/src/index.ts"
      ],
      "@documind/types/*": [
        "../../packages/types/src/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "types": [
        "./types/index"
      ],
      "types/*": [
        "./types/*"
      ]
    }
  }
}