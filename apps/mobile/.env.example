## Optional override. During `pnpm mobile:start|ios|android|web`, Documind
## auto-generates `apps/mobile/.env.development.local` with the current LAN API URL
## when this variable is unset. Set this explicitly to disable that auto-sync.
EXPO_PUBLIC_API_URL=

## Optional override for the auto-generated dev API port. Defaults to 3000.
EXPO_PUBLIC_API_PORT=3000

EXPO_PUBLIC_GOOGLE_ANDROID_ID=
EXPO_PUBLIC_GOOGLE_IOS_ID=
EXPO_PUBLIC_GOOGLE_WEB_ID=

EXPO_PUBLIC_GITHUB_CLIENT_ID=

EXPO_PUBLIC_GOOGLE_REDIRECT_URI=
