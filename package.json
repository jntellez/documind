{
  "name": "documind",
  "version": "1.0.0",
  "scripts": {
    "start": "pnpm --filter @documind/mobile start",
    "android": "pnpm --filter @documind/mobile android",
    "ios": "pnpm --filter @documind/mobile ios",
    "web": "pnpm --filter @documind/mobile web",
    "api:dev": "pnpm --filter @documind/api dev",
    "api:start": "pnpm --filter @documind/api start",
    "api:typecheck": "pnpm --filter @documind/api typecheck",
    "mobile:start": "pnpm --filter @documind/mobile start",
    "mobile:android": "pnpm --filter @documind/mobile android",
    "mobile:ios": "pnpm --filter @documind/mobile ios",
    "mobile:web": "pnpm --filter @documind/mobile web"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "private": true,
  "packageManager": "pnpm@10.33.0"
}
