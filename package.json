{
  "name": "documind",
  "version": "1.0.0",
  "scripts": {
    "start": "pnpm run mobile:start",
    "android": "pnpm run mobile:android",
    "ios": "pnpm run mobile:ios",
    "web": "pnpm run mobile:web",
    "web:dev": "pnpm --filter @documind/web dev",
    "web:build": "pnpm --filter @documind/web build",
    "web:start": "pnpm --filter @documind/web start",
    "web:test": "pnpm --filter @documind/web test",
    "web:typecheck": "pnpm --filter @documind/web typecheck",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api postgres",
    "api:dev": "pnpm --filter @documind/api dev",
    "api:start": "pnpm --filter @documind/api start",
    "api:test": "pnpm --filter @documind/api test",
    "api:typecheck": "pnpm --filter @documind/api typecheck",
    "types:typecheck": "pnpm --filter @documind/types typecheck",
    "mobile:config": "pnpm --filter @documind/mobile config:check",
    "mobile:start": "pnpm --filter @documind/mobile start",
    "mobile:lan": "REACT_NATIVE_PACKAGER_HOSTNAME=${REACT_NATIVE_PACKAGER_HOSTNAME:-192.168.1.9} pnpm --filter @documind/mobile start --lan",
    "mobile:android": "pnpm --filter @documind/mobile android",
    "mobile:ios": "pnpm --filter @documind/mobile ios",
    "mobile:test": "pnpm --filter @documind/mobile test",
    "mobile:typecheck": "pnpm --filter @documind/mobile typecheck",
    "mobile:web": "pnpm --filter @documind/mobile web",
    "test": "pnpm run api:test && pnpm run mobile:test && pnpm run web:test",
    "typecheck": "pnpm run types:typecheck && pnpm run mobile:typecheck && pnpm run api:typecheck && pnpm run web:typecheck",
    "validate": "pnpm run typecheck && pnpm run mobile:config && pnpm run web:build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "private": true,
  "packageManager": "pnpm@10.33.0"
}
